// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String?
  link        String?
  techStack   String['React', 'postgresql']
  createdAt   DateTime @default(now())
}